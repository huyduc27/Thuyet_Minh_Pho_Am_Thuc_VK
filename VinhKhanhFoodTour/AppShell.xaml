<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="VinhKhanhFoodTour.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:VinhKhanhFoodTour.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarBackgroundColor="White"
    Shell.TabBarTitleColor="#e94560"
    Shell.TabBarUnselectedColor="#BBBBBB"
    Shell.BackgroundColor="White"
    Shell.ForegroundColor="#1a1a2e">

    <TabBar>
        <ShellContent Title="Danh sach"
                      Icon="tab_list.svg"
                      ContentTemplate="{DataTemplate views:PoiListPage}"/>
        <ShellContent Title="Ban do"
                      Icon="tab_map.svg"
                      ContentTemplate="{DataTemplate views:MapPage}"/>
        <ShellContent Title="Cai dat"
                      Icon="tab_settings.svg"
                      ContentTemplate="{DataTemplate views:SettingsPage}"/>
    </TabBar>

</Shell>
